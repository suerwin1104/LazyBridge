# --- Core Discord Configuration ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
OWNER_ID=your_discord_user_id_here

# Apify Token (新聞抓取 - 依賴於 services/apify_news.py)
APIFY_TOKEN=your_apify_token_here

# --- Phase 2: Headless LLM API Keys ---
# 填寫其中一個即可啟動「無頭模式」 (依賴於 services/ai_engine.py)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Infrastructure ---
# Redis Configuration (預設)
REDIS_URL=redis://localhost:6379
TASK_QUEUE=lazybridge_tasks

# Database Configuration (Phase 3 - SQLAlchemy Async)
# 預設使用 SQLite: sqlite+aiosqlite:///scheduler_history.sqlite
# 生產環境建議 PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/lazybridge
DATABASE_URL=sqlite+aiosqlite:///scheduler_history.sqlite

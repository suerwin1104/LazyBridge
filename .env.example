# Discord Bot Configuration
DISCORD_BOT_TOKEN=
OWNER_ID=

# AI API Keys (At least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# New AI Skill/Service integration (Apify)
APIFY_TOKEN=

# Redis Configuration
REDIS_URL=redis://localhost:6379
TASK_QUEUE=lazybridge_tasks

# Database Configuration
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/dbname
# SQLite: sqlite+aiosqlite:///scheduler_history.sqlite
DATABASE_URL=sqlite+aiosqlite:///scheduler_history.sqlite

# Token Optimization
TOONIFY_ENABLED=true

# Reports Server & External Access
# Example: http://100.x.y.z:8080 (Tailscale) or https://subdomain.loca.lt
REPORTS_BASE_URL=http://localhost:8080

# Cloudflare Dynamic Link Hub (Optional)
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# Multi-Service Mapping
# Format: service1:port1,service2:port2
MULTI_SERVICE_MAP=report:8080,hbms:3000
